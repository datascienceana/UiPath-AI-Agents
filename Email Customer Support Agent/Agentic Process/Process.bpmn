    <bpmn:serviceTask id="Activity_Tldyba" name="Answer the question">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartAgentJob" version="v2" />
          <uipath:context>
            <uipath:input name="name" type="string" value="=bindings.bcd6rko7b" />
            <uipath:input name="folderPath" type="string" value="=bindings.bjbSCmbmJ" />
            <uipath:input name="_label" type="string" value="Uipath Eugene" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"sender_name":{"type":"string","title":"sender_name"},"sender_email":{"type":"string","title":"sender_email"},"email_subject":{"type":"string","title":"email_subject"},"email_body":{"type":"string","title":"email_body"},"email_id":{"type":"string","title":"email_id"}},"required":["sender_name","sender_email","email_subject","email_body","email_id"]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"sender_name":"=vars.response.From.Name","sender_email":"=vars.response.From.Email","email_subject":"=vars.response.Subject","email_body":"=vars.response.Body","email_id":"=vars.response.ID"}]]></uipath:input>
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error" />
          <uipath:output name="content" type="string" source="=content" var="content" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>edge_dgOS0f</bpmn:incoming>
      <bpmn:outgoing>edge_V3VxGt</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Activity_N7QJHC" name="Reply to email">
      <bpmn:documentation>Email gets sent with Eugene's answer</bpmn:documentation>
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Intsvc.ActivityExecution" version="v1" />
          <uipath:context>
            <uipath:input name="connectorKey" type="string" value="uipath-google-gmail" />
            <uipath:input name="connection" type="string" value="=bindings.b6T5vyoO2" />
            <uipath:input name="folderKey" type="string" value="=bindings.bXj0RlhIe" />
            <uipath:input name="resourceKey" type="string" value="3f29bd83-8c8b-4eef-af74-934fab24979f" />
            <uipath:input name="operation" type="string" value="ReplyToEmailV2" />
            <uipath:input name="objectName" type="string" value="EmailReply" />
            <uipath:input name="method" type="string" value="POST" />
            <uipath:input name="path" type="string" value="/EmailReply" />
            <uipath:input name="metadata" type="json"><![CDATA[{"designTimeMetadata":{"connectorLogoUrl":"https://cloud.uipath.com/elements_/scaleunit_/17d5b0e1-f66c-4b4d-b4aa-620d35a563cf/v3/element/elements/uipath-google-gmail/image","activityDesignerVersion":"2","activityDisplayName":"Reply to Email","activityDescription":"Sends a reply to an email based on email ID","activityHelpUrlTemplate":"https://docs.uipath.com/{0}/activities/other/latest/integration-service/uipath-google-gmail-Reply-To-Email","activityConfig":{"isCurated":true,"operation":null}},"metadataState":{"jsonSchema":{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"threadId":{"title":"Email thread identifier","type":"string","description":"Unique identifier for the email conversation thread."},"labelIds[*]":{"title":"Label identifiers","type":"string","description":"Unique identifiers for the labels associated with the email."},"id":{"title":"Email identifier","type":"string","description":"A unique identifier for the email message."}},"definitions":{}}},"telemetryData":{"operationType":"Create","objectName":"EmailReply","objectDisplayName":"Email Reply","connectorKey":"uipath-google-gmail","connectorName":"Gmail","primaryKeyName":"id"},"inputMetadata":{"type":"multipart","multipart":{"bodyFieldName":"body"}},"errorState":{"hasError":false},"bindings":[]}]]></uipath:input>
          </uipath:context>
          <uipath:input name="replyToAll" type="string" value="true" target="query" />
          <uipath:input name="saveAsDraft" type="string" value="false" target="query" />
          <uipath:input name="id" type="string" value="=vars.response.ID" target="query" />
          <uipath:input name="body" type="json" target="body"><![CDATA[{"importance":"normal","body":"=vars.content.Replace(\".\",\"<br><br>\")"}]]></uipath:input>
          <uipath:output name="id" type="string" source="=response.id" var="id" />
          <uipath:output name="response" type="jsonSchema" source="=response" var="response2" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>edge_V3VxGt</bpmn:incoming>
      <bpmn:outgoing>edge_R5zFiY</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="Event_y3B0XC">
      <bpmn:incoming>edge_R5zFiY</bpmn:incoming>
    </bpmn:endEvent>
