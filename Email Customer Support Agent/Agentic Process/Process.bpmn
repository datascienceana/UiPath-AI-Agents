    <bpmn:startEvent id="Event_start" name="">
      <bpmn:extensionElements>
        <uipath:entryPointId value="bd1b6d7e-c58d-45b5-9d33-d73a99967415" />
        <uipath:event version="v1">
          <uipath:type value="Intsvc.EventTrigger" version="v1" />
          <uipath:context>
            <uipath:input name="connectorKey" type="string" value="uipath-google-gmail" />
            <uipath:input name="connection" type="string" value="=bindings.b6T5vyoO2" />
            <uipath:input name="folderKey" type="string" value="=bindings.bXj0RlhIe" />
            <uipath:input name="resourceKey" type="string" value="3f29bd83-8c8b-4eef-af74-934fab24979f" />
            <uipath:input name="operation" type="string" value="EMAIL_RECEIVED" />
            <uipath:input name="objectName" type="string" value="Message" />
            <uipath:input name="metadata" type="json"><![CDATA[{"designTimeMetadata":{"connectorLogoUrl":"https://cloud.uipath.com/elements_/scaleunit_/17d5b0e1-f66c-4b4d-b4aa-620d35a563cf/v3/element/elements/uipath-google-gmail/image","activityDisplayName":"Email Received","activityDescription":"Triggers when an email is received in your inbox.","activityHelpUrlTemplate":"https://docs.uipath.com/{0}/activities/other/latest/integration-service/uipath-google-gmail-Email-Received","activityConfig":{"isCurated":true,"operation":"EMAIL_RECEIVED"},"triggerActivity":{"eventFields":{"ParentFolders[*].ID":"INBOX"},"filterBuilder":{"expression":"(contains(Subject, 'Uipath') && contains(Subject, 'uipath') && contains(Subject, 'UIPATH'))"}},"designTimeLookups":{"ParentFolders[*].ID":[{"id":"INBOX","title":"Inbox"}]}},"metadataState":{"jsonSchema":{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"Attachments[*]":{"title":"Attachments","type":"array","items":{"$ref":"#/definitions/Attachments[*]"}},"BCC[*]":{"title":"Bcc","type":"array","items":{"$ref":"#/definitions/BCC[*]"}},"CC[*]":{"title":"Cc","type":"array","items":{"$ref":"#/definitions/CC[*]"}},"HasAttachments":{"title":"With attachments only","type":"boolean"},"Categories[*]":{"title":"Categories","type":"array","items":{"$ref":"#/definitions/Categories[*]"}},"To[*]":{"title":"To","type":"array","items":{"$ref":"#/definitions/To[*]"}},"From":{"title":"From","$ref":"#/definitions/From"},"Subject":{"title":"Subject","type":"string"},"ParentFolders[*]":{"title":"Parent folders","type":"array","items":{"$ref":"#/definitions/ParentFolders[*]"}},"Importance":{"title":"Importance","type":"string"},"Sensitivity":{"title":"Sensitivity","type":"string"},"Type":{"title":"Type","type":"string"},"ThreadID":{"title":"Thread","type":"string"},"ID":{"title":"Id","type":"string"},"Body":{"title":"Body","type":"string"}},"definitions":{"Attachments[*]":{"type":"object","properties":{"MIMEType":{"title":"Attachment mime type","type":"string"},"ID":{"title":"Attachment ID","type":"string"},"Name":{"title":"Attachment name","type":"string"},"Size":{"title":"Attachment size","type":"integer"}}},"BCC[*]":{"type":"object","properties":{"Name":{"title":"Bcc name","type":"string"},"Email":{"title":"Bcc email","type":"string"}}},"CC[*]":{"type":"object","properties":{"Email":{"title":"Cc","type":"string"},"Name":{"title":"Cc name","type":"string"}}},"Categories[*]":{"type":"object","properties":{"ID":{"title":"Category ID","type":"string"},"Name":{"title":"Category name","type":"string"}}},"To[*]":{"type":"object","properties":{"Email":{"title":"To","type":"string"},"Name":{"title":"Recipient name","type":"string"}}},"From":{"type":"object","properties":{"Email":{"title":"From","type":"string"},"Name":{"title":"Sender name","type":"string"}}},"ParentFolders[*]":{"type":"object","properties":{"ID":{"title":"Email folder or label","type":"string"},"Name":{"title":"Label","type":"string"}}}}}},"telemetryData":{"operation":"EMAIL_RECEIVED","objectName":"Message","connectorKey":"uipath-google-gmail","connectorName":"Gmail","primaryKeyName":""},"inputMetadata":{},"errorState":{"hasError":false},"bindings":[{"resource":"Property","key":"EMAIL_RECEIVED","value":{"ParentFolders[*].ID":{"defaultValue":"INBOX","isExpression":false}},"metadata":{"TriggerCreateParameters":"ParentFolders[*].ID","DebugQueryParameters":"ParentFolders[*].ID","BindingsVersion":"2.2","ObjectName":"Message"}}]}]]></uipath:input>
          </uipath:context>
          <uipath:input name="body" type="json" target="body"><![CDATA[{"filters":{"expression":"(ParentFolders[?ID == 'INBOX']) && ((contains(Subject, 'Uipath') && contains(Subject, 'uipath') && contains(Subject, 'UIPATH')))","variables":{}}}]]></uipath:input>
